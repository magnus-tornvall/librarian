{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["/ABSOLUTE/PATH/TO/librarian/adapters/claude-code/hook.ts"],
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["/ABSOLUTE/PATH/TO/librarian/adapters/claude-code/hook.ts"],
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["/ABSOLUTE/PATH/TO/librarian/adapters/claude-code/hook.ts"],
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["/ABSOLUTE/PATH/TO/librarian/adapters/claude-code/hook.ts"],
            "timeout": 10
          }
        ]
      }
    ]
  }
}
